    {
      "parameters": {
        "url": "https://mine-yours-co.myshopify.com/admin/api/2024-01/orders.json",
        "sendQuery": true,
        "queryParameters": {"parameters": [
          {"name": "status", "value": "any"},
          {"name": "financial_status", "value": "refunded,partially_refunded"},
          {"name": "updated_at_min", "value": "={{ new Date(Date.now() - 86400000).toISOString().split('T')[0] }}"},
          {"name": "updated_at_max", "value": "={{ new Date().toISOString().split('T')[0] }}"}
        ]},
        "sendHeaders": true,
