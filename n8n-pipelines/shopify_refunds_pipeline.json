        "options": {"response": {"response": {"fullResponse": true, "responseFormat": "json"}}}
      },
      "id": "sr-fetch", "name": "Get First Page",
      "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [368, -192],
      "credentials": {"httpHeaderAuth": {"id": "REPLACE_WITH_SHOPIFY_CREDENTIAL_ID", "name": "Shopify Mine & Yours"}}
    },
    {
      "parameters": {"jsCode": "const resp = items[0].json;\nconst headers = resp.headers || {};\nconst body = resp.body || {};\nconst data = body.orders || [];\nconst linkHeader = headers.link || headers['Link'] || '';\nconst nextMatch = linkHeader.match(/<([^>]+)>; rel=\"next\"/);\nconst nextUrl = nextMatch ? nextMatch[1] : null;\nreturn [{ json: { allData: data, nextUrl: nextUrl, pageCount: 1 } }];"},
      "id": "sr-init", "name": "Initialize Pagination",
      "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [608, -192]
    },
    {
      "parameters": {"conditions": {"string": [{"value1": "={{ $json.nextUrl }}", "operation": "isNotEmpty"}]}},
      "id": "sr-if", "name": "Has More Pages?",
      "type": "n8n-nodes-base.if", "typeVersion": 1, "position": [816, -192]
    },
    {
      "parameters": {
        "url": "={{ $json.nextUrl }}", "sendHeaders": true,
        "headerParameters": {"parameters": [{"name": "X-Shopify-Access-Token", "value": "REPLACE_WITH_SHOPIFY_ACCESS_TOKEN"}]},
        "options": {"response": {"response": {"fullResponse": true, "responseFormat": "json"}}}
      },
      "id": "sr-next", "name": "Fetch Next Page",
      "type": "n8n-nodes-base.httpRequest", "typeVersion": 4.2, "position": [1008, -384],
      "credentials": {"httpHeaderAuth": {"id": "REPLACE_WITH_SHOPIFY_CREDENTIAL_ID", "name": "Shopify Mine & Yours"}}
    },
    {
      "parameters": {"jsCode": "const prev = $node[\"Has More Pages?\"].json;\nconst curr = items[0].json;\nconst body = curr.body || {};\nconst newData = body.orders || [];\nconst allData = prev.allData.concat(newData);\nconst headers = curr.headers || {};\nconst linkHeader = headers.link || headers['Link'] || '';\nconst nextMatch = linkHeader.match(/<([^>]+)>; rel=\"next\"/);\nconst nextUrl = nextMatch ? nextMatch[1] : null;\nif (prev.pageCount >= 100) return [{ json: { allData: allData, nextUrl: null, pageCount: prev.pageCount + 1 } }];\nreturn [{ json: { allData: allData, nextUrl: nextUrl, pageCount: prev.pageCount + 1 } }];"},
      "id": "sr-merge", "name": "Merge Pages",
      "type": "n8n-nodes-base.code", "typeVersion": 2, "position": [1216, -384]
    },
    {
      "parameters": {"jsCode": "const today = new Date().toISOString().split('T')[0];\nconst all = items[0].json.allData || [];\nconst results = [];\nfunction getWeek(ds){\n  var d=new Date(ds); d.setHours(0,0,0,0);\n  d.setDate(d.getDate()+3-(d.getDay()+6)%7);\n  var w=new Date(d.getFullYear(),0,4);\n  return 1+Math.round(((d-w)/86400000-3+(w.getDay()+6)%7)/7);\n}\nfor (var i=0;i<all.length;i++){\n  var o=all[i];\n  var refunds=o.refunds||[];\n  for (var r=0;r<refunds.length;r++){\n    var ref=refunds[r];\n    var rd=(ref.created_at||today).split('T')[0];\n    var dobj=new Date(ref.created_at||today);\n    var yr=dobj.getFullYear().toString();\n    var wk=getWeek(ref.created_at||today).toString();\n    var ym=yr+'|'+(dobj.getMonth()+1);\n    var adjs=ref.order_adjustments||[];\n    var sadj=adjs.find(function(a){return a.kind==='shipping_refund';})||{};\n    var dadj=adjs.find(function(a){return a.kind==='refund_discrepancy';})||{};\n    var rlis=ref.refund_line_items||[];\n    if(rlis.length===0){\n      results.push({json:{\n        date:rd, account_name:'mine-yours-co.myshopify.com',\n        order_id:(o.id||'').toString(), order_name:o.name||'',\n        source:'shopify', order_refunds:'gid://shopify/Refund/'+ref.id,\n        order_refund_discrepancy_amount:parseFloat(dadj.amount)||0,\n        order_total_shipping_refunded_price:parseFloat(sadj.amount)||0,\n        line_item__refunds:null, line_item__refundable_quantity:null,\n        line_item__refunds_price:null, line_item__refunds_quantity:null,\n        line_item__refunds_subtotal:null, line_item__refunds_total_tax:null,\n        week:wk, year:yr, year_month:ym\n      }});\n    } else {\n      for (var k=0;k<rlis.length;k++){\n        var rli=rlis[k];\n        results.push({json:{\n          date:rd, account_name:'mine-yours-co.myshopify.com',\n          order_id:(o.id||'').toString(), order_name:o.name||'',\n          source:'shopify', order_refunds:'gid://shopify/Refund/'+ref.id,\n          order_refund_discrepancy_amount:parseFloat(dadj.amount)||0,\n          order_total_shipping_refunded_price:parseFloat(sadj.amount)||0,\n          line_item__refunds:null,\n          line_item__refundable_quantity:rli.quantity||0,\n          line_item__refunds_price:parseFloat(rli.subtotal)||0,\n          line_item__refunds_quantity:rli.quantity||0,\n          line_item__refunds_subtotal:parseFloat(rli.subtotal)||0,\n          line_item__refunds_total_tax:parseFloat(rli.total_tax)||0,\n          week:wk, year:yr, year_month:ym\n        }});\n      }\n    }\n  }\n}\nif (results.length === 0) return [{json:{message:'No refunds yesterday'}}];\nreturn results;"},
      "id": "sr-transform", "name": "Transform",
